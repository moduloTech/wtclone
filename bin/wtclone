#!/usr/bin/env bash
# wtclone — bootstrap a git repo in worktree layout and manage worktrees.
#
# Subcommands:
#   init <url> [name]   clone + safe fetch refspec + default-branch worktree
#   add <branch> [base] add a worktree, tracking origin/<branch> if present
#   rm <branch>         remove a worktree safely (checks uncommitted / unpushed)
#   fix                 migrate a <= 0.1.0 layout to the safe fetch refspec
#
# Shortcut: `wtclone <url> [name]` is equivalent to `wtclone init <url> [name]`.

set -euo pipefail

WTCLONE_VERSION="0.2.0"
SAFE_FETCH_REFSPEC='+refs/heads/*:refs/remotes/origin/*'

usage() {
  cat <<'EOF'
Usage:
  wtclone <git-url> [name]          shortcut for `wtclone init <git-url> [name]`
  wtclone init <git-url> [name]     clone into worktree layout and create default-branch worktree
  wtclone add <branch> [base]       add a worktree; tracks origin/<branch> if it exists,
                                    else creates a new branch from [base] (default: origin/HEAD)
  wtclone rm <branch> [options]     remove a worktree safely
                                      --force        skip uncommitted/unpushed checks
                                      --keep-branch  keep the local branch ref
  wtclone fix                       migrate a pre-0.2.0 layout to the safe fetch refspec
                                    and set upstream on existing worktrees

Environment:
  WTCLONE_ROOT                      root directory for new projects (default: $HOME/Projects)

On successful init/add, the absolute path of the created worktree is printed as the
last line on stdout. All other output goes to stderr so a shell wrapper can `cd "$(wtclone ...)"`.
EOF
}

die() { printf 'wtclone: %s\n' "$*" >&2; exit 1; }
log() { printf 'wtclone: %s\n' "$*" >&2; }

normalize() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr '_' '-'
}

validate_dns_label() {
  local label="$1" max_len=50
  [ -n "$label" ] || die "derived name is empty"
  [ ${#label} -le $max_len ] || die "name '$label' exceeds $max_len chars"
  printf '%s' "$label" | grep -Eq '^[a-z0-9]([a-z0-9-]*[a-z0-9])?$' \
    || die "name '$label' is not a valid DNS label (allowed: [a-z0-9-], no leading/trailing hyphen)"
}

derive_name_from_url() {
  local url="$1" path repo parent
  path=$(printf '%s' "$url" | sed -E 's|^[^:]+:||; s|^[a-z]+://[^/]+/||; s|\.git$||')
  [ -n "$path" ] || die "cannot parse path from URL: $url"
  repo=$(basename "$path")
  parent=$(basename "$(dirname "$path")")
  repo=$(normalize "$repo")
  parent=$(normalize "$parent")
  if [ "$parent" = "." ] || [ "$parent" = "/" ] || [ -z "$parent" ] || [ "$repo" = "$parent" ]; then
    printf '%s\n' "$repo"
  else
    printf '%s-%s\n' "$parent" "$repo"
  fi
}

# Walk up from PWD looking for a wtclone layout (.bare/ + .git pointer file).
find_layout_root() {
  local dir="$PWD"
  while [ -n "$dir" ] && [ "$dir" != "/" ]; do
    if [ -d "$dir/.bare" ] && [ -f "$dir/.git" ]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir=$(dirname "$dir")
  done
  return 1
}

ensure_layout() {
  local root
  root=$(find_layout_root) || die "not inside a wtclone layout (no .bare/ with .git pointer found)"
  cd "$root"
}

# ---- cmd_init ------------------------------------------------------------

cmd_init() {
  local url="${1:-}" name="${2:-}"
  [ -n "$url" ] || { usage >&2; exit 2; }

  if [ -z "$name" ]; then
    name=$(derive_name_from_url "$url")
  else
    name=$(normalize "$name")
  fi
  validate_dns_label "$name"

  local root="${WTCLONE_ROOT:-$HOME/Projects}"
  local target="$root/$name"
  [ ! -e "$target" ] || die "target exists: $target"

  mkdir -p "$target"
  cd "$target"

  log "cloning $url into $target/.bare"
  git clone --bare "$url" .bare 1>&2
  printf 'gitdir: ./.bare\n' > .git

  # Switch to safe refspec and re-fetch so origin/* refs populate.
  git --git-dir=.bare config remote.origin.fetch "$SAFE_FETCH_REFSPEC"
  git --git-dir=.bare fetch origin --prune 1>&2

  local default_branch
  default_branch=$(git --git-dir=.bare symbolic-ref --short HEAD 2>/dev/null) \
    || die "remote has no default branch (HEAD unresolved); clone kept at $target"

  # Delete the mirrored refs/heads/* populated by `clone --bare` — they are
  # stale the moment the refspec changes. The worktree-add below will recreate
  # refs/heads/<default_branch> pointing at origin/<default_branch>.
  git --git-dir=.bare for-each-ref --format='delete %(refname)' refs/heads/ \
    | git --git-dir=.bare update-ref --stdin

  # Wire refs/remotes/origin/HEAD so future add/fix calls know the default
  # branch without a network round-trip.
  git --git-dir=.bare symbolic-ref refs/remotes/origin/HEAD "refs/remotes/origin/$default_branch"

  log "creating worktree $default_branch tracking origin/$default_branch"
  git worktree add -b "$default_branch" "$default_branch" "origin/$default_branch" 1>&2

  printf '%s\n' "$target/$default_branch"
}

# ---- cmd_add -------------------------------------------------------------

# Print a tailored diagnosis for an existing refs/heads/<branch> that blocks
# `wtclone add`. Distinguishes (1) checked out in another worktree, (2) orphan
# ref matching origin, (3) orphan ref diverged from origin, (4) orphan ref with
# no origin counterpart. Writes to stderr; caller is responsible for exit.
diagnose_existing_branch() {
  local branch="$1" checked_out_at
  checked_out_at=$(git --git-dir=.bare worktree list --porcelain | awk -v b="refs/heads/$branch" '
    $1=="worktree" { path=$2 }
    $1=="branch" && $2==b { print path; exit }
  ')
  if [ -n "$checked_out_at" ]; then
    {
      printf "wtclone: branch '%s' is already checked out at:\n" "$branch"
      printf "    %s\n" "$checked_out_at"
      printf '\n'
      printf "wtclone: a branch can only be checked out in one worktree at a time.\n"
    } >&2
    return
  fi

  local local_sha
  local_sha=$(git --git-dir=.bare rev-parse --short "refs/heads/$branch")

  if ! git --git-dir=.bare show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    {
      printf "wtclone: branch '%s' exists locally with no worktree attached (orphan ref).\n" "$branch"
      printf "    local:  refs/heads/%s @ %s\n" "$branch" "$local_sha"
      printf "    origin: (no refs/remotes/origin/%s — branch is not on the remote)\n" "$branch"
      printf '\n'
      printf "wtclone: this is a local-only branch; attach it with:\n"
      printf "    git worktree add %s\n" "$branch"
    } >&2
    return
  fi

  local origin_sha
  origin_sha=$(git --git-dir=.bare rev-parse --short "refs/remotes/origin/$branch")
  if [ "$local_sha" = "$origin_sha" ]; then
    {
      printf "wtclone: branch '%s' exists locally with no worktree attached (orphan ref).\n" "$branch"
      printf "    local:  refs/heads/%s @ %s\n" "$branch" "$local_sha"
      printf "    origin: refs/remotes/origin/%s @ %s\n" "$branch" "$origin_sha"
      printf '\n'
      printf "wtclone: local matches origin — safe to attach with:\n"
      printf "    git worktree add %s\n" "$branch"
    } >&2
    return
  fi

  local ahead behind
  ahead=$(git --git-dir=.bare rev-list --count "refs/remotes/origin/$branch..refs/heads/$branch" 2>/dev/null || echo "?")
  behind=$(git --git-dir=.bare rev-list --count "refs/heads/$branch..refs/remotes/origin/$branch" 2>/dev/null || echo "?")
  {
    printf "wtclone: branch '%s' exists locally with no worktree attached (orphan ref).\n" "$branch"
    printf "    local:      refs/heads/%s @ %s\n" "$branch" "$local_sha"
    printf "    origin:     refs/remotes/origin/%s @ %s\n" "$branch" "$origin_sha"
    printf "    divergence: %s ahead, %s behind origin/%s\n" "$ahead" "$behind" "$branch"
    printf '\n'
    printf "wtclone: local and origin differ. Choose:\n"
    printf "  - attach the local branch (keeps any unpushed work):\n"
    printf "      git worktree add %s\n" "$branch"
    printf "  - discard the local ref and re-create from origin/%s:\n" "$branch"
    printf "      git --git-dir=.bare branch -D %s\n" "$branch"
    printf "      wtclone add %s\n" "$branch"
  } >&2
}

cmd_add() {
  local branch="${1:-}" base="${2:-}"
  [ -n "$branch" ] || die "usage: wtclone add <branch> [base]"

  ensure_layout

  log "fetching origin"
  git --git-dir=.bare fetch origin --prune 1>&2

  if git --git-dir=.bare show-ref --verify --quiet "refs/heads/$branch"; then
    diagnose_existing_branch "$branch"
    exit 1
  fi

  if git --git-dir=.bare show-ref --verify --quiet "refs/remotes/origin/$branch"; then
    log "worktree $branch will track origin/$branch"
    git worktree add -b "$branch" "$branch" "origin/$branch" 1>&2
  else
    if [ -z "$base" ]; then
      base=$(git --git-dir=.bare symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null) \
        || die "origin/HEAD not set and no base provided; run 'wtclone fix' or pass a base explicitly"
    fi
    log "worktree $branch will be a new branch off $base (no upstream)"
    git worktree add --no-track -b "$branch" "$branch" "$base" 1>&2
  fi

  printf '%s\n' "$PWD/$branch"
}

# ---- cmd_rm --------------------------------------------------------------

cmd_rm() {
  local branch="" force=false keep_branch=false
  while [ $# -gt 0 ]; do
    case "$1" in
      --force)        force=true ;;
      --keep-branch)  keep_branch=true ;;
      -*)             die "unknown option: $1" ;;
      *)
        [ -z "$branch" ] || die "unexpected argument: $1"
        branch="$1"
        ;;
    esac
    shift
  done
  [ -n "$branch" ] || die "usage: wtclone rm <branch> [--force] [--keep-branch]"

  ensure_layout

  local wt_path
  wt_path=$(git --git-dir=.bare worktree list --porcelain | awk -v b="refs/heads/$branch" '
    $1=="worktree" { path=$2 }
    $1=="branch" && $2==b { print path; found=1; exit }
    END { exit !found }
  ') || die "no worktree found on branch '$branch'"

  if ! $force; then
    if [ -n "$(git -C "$wt_path" status --porcelain 2>/dev/null)" ]; then
      die "worktree '$wt_path' has uncommitted changes (use --force to override)"
    fi
    local upstream unpushed
    upstream=$(git -C "$wt_path" rev-parse --abbrev-ref "$branch@{upstream}" 2>/dev/null || true)
    if [ -n "$upstream" ]; then
      unpushed=$(git -C "$wt_path" rev-list --count "$upstream..$branch" 2>/dev/null || echo 0)
      [ "$unpushed" -eq 0 ] || die "branch '$branch' has $unpushed unpushed commit(s) vs $upstream (use --force)"
    fi
    # Gitignored entries (build artifacts, caches, vendored deps, …) pass git's
    # cleanliness check but block the final rmdir with "Directory not empty".
    # Surface this explicitly instead of letting the user decode git's terse error.
    local ignored
    ignored=$(git -C "$wt_path" ls-files --others --ignored --exclude-standard --directory 2>/dev/null || true)
    if [ -n "$ignored" ]; then
      {
        printf "wtclone: worktree '%s' contains gitignored entries that 'git worktree remove' will not delete:\n" "$wt_path"
        printf '%s\n' "$ignored" | sed 's/^/  /'
        printf '\n'
        printf "wtclone: 'git worktree remove' refuses to rmdir a directory that still holds these\n"
        printf "         (it only handles tracked content + non-ignored untracked files).\n"
        printf '\n'
        printf "wtclone: to remove the worktree along with these entries:\n"
        printf "    wtclone rm %s --force\n" "$branch"
        printf '\n'
        printf "wtclone: or clean them first, then re-run:\n"
        printf "    git -C '%s' clean -fdX\n" "$wt_path"
      } >&2
      exit 1
    fi
  fi

  log "removing worktree $wt_path"
  if $force; then
    git --git-dir=.bare worktree remove --force "$wt_path" 1>&2
  else
    git --git-dir=.bare worktree remove "$wt_path" 1>&2
  fi

  if ! $keep_branch; then
    if git --git-dir=.bare show-ref --verify --quiet "refs/heads/$branch"; then
      log "deleting local branch $branch"
      git --git-dir=.bare branch -D "$branch" 1>&2
    fi
  fi
}

# ---- cmd_fix -------------------------------------------------------------

cmd_fix() {
  ensure_layout

  local current
  current=$(git --git-dir=.bare config remote.origin.fetch 2>/dev/null || true)
  if [ "$current" != "$SAFE_FETCH_REFSPEC" ]; then
    log "rewriting remote.origin.fetch: '$current' -> '$SAFE_FETCH_REFSPEC'"
    git --git-dir=.bare config remote.origin.fetch "$SAFE_FETCH_REFSPEC"
  else
    log "refspec already safe"
  fi

  log "fetching origin"
  git --git-dir=.bare fetch origin --prune 1>&2

  if ! git --git-dir=.bare symbolic-ref --quiet refs/remotes/origin/HEAD >/dev/null 2>&1; then
    local default_branch
    default_branch=$(git --git-dir=.bare symbolic-ref --short HEAD 2>/dev/null || true)
    if [ -n "$default_branch" ] \
       && git --git-dir=.bare show-ref --verify --quiet "refs/remotes/origin/$default_branch"; then
      git --git-dir=.bare symbolic-ref refs/remotes/origin/HEAD "refs/remotes/origin/$default_branch"
      log "set refs/remotes/origin/HEAD -> refs/remotes/origin/$default_branch"
    fi
  fi

  # For each existing worktree's branch, set upstream to origin/<branch> when possible.
  while IFS='|' read -r wt_path wt_branch; do
    [ -n "$wt_path" ] && [ -n "$wt_branch" ] || continue
    if git --git-dir=.bare show-ref --verify --quiet "refs/remotes/origin/$wt_branch"; then
      local current_upstream
      current_upstream=$(git -C "$wt_path" rev-parse --abbrev-ref "$wt_branch@{upstream}" 2>/dev/null || true)
      if [ "$current_upstream" != "origin/$wt_branch" ]; then
        git -C "$wt_path" branch --set-upstream-to="origin/$wt_branch" "$wt_branch" 1>&2
        log "set upstream for $wt_branch -> origin/$wt_branch ($wt_path)"
      fi
    fi
  done < <(git --git-dir=.bare worktree list --porcelain | awk '
    $1=="worktree" { path=$2 }
    $1=="branch"   { sub("refs/heads/","",$2); print path"|"$2 }
  ')
}

# ---- dispatcher ----------------------------------------------------------

wtclone_main() {
  case "${1:-}" in
    -h|--help)    usage; exit 0 ;;
    -v|--version) printf 'wtclone %s\n' "$WTCLONE_VERSION"; exit 0 ;;
    '')           usage >&2; exit 2 ;;
    init)         shift; cmd_init "$@" ;;
    add)          shift; cmd_add  "$@" ;;
    rm)           shift; cmd_rm   "$@" ;;
    fix)          shift; cmd_fix  "$@" ;;
    *)            cmd_init "$@" ;;   # shortcut: wtclone <url> [name]
  esac
}

# Only run main when executed directly (not when sourced by tests).
if [ "${BASH_SOURCE[0]}" = "$0" ]; then
  wtclone_main "$@"
fi
